# Database
DATABASE_URL=

# Auth
JWT_SECRET=
JWT_EXPIRY_HOURS=24

# AI Enrichment Provider (gemini or groq — defaults to groq if GROQ_API_KEY is set)
ENRICHMENT_PROVIDER=groq

# Groq (default provider — Llama 3.1 70B, fast and no daily quota issues)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (fallback — subject to 50 calls/day quota)
GEMINI_API_KEY=your-google-ai-studio-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# Execution
EXECUTOR_MAX_CONCURRENCY=6
EXECUTOR_TIMEOUT_SECONDS=30
DOCKER_IMAGE=golang:1.23-alpine
SANDBOX_BASE_DIR=/tmp/koder
BUILD_CACHE_DIR=/tmp/go-build-cache

# Sandbox (optional — empty = use local Docker)
SANDBOX_URL=https://koder-production.up.railway.app

# Go version for generated test modules (default "1.23")
GO_VERSION=1.23

# Server
PORT=8080
ENVIRONMENT=development

# Google OAuth2 (for Sign-In)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Resend (email notifications for feedback + password reset)
RESEND_API_KEY=

# Frontend URL (for password reset links in emails)
FRONTEND_URL=https://koder.vercel.app

# CORS
ALLOWED_ORIGIN=https://koder.vercel.app
