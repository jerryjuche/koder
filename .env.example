# Database
DATABASE_URL=postgres://user:password@host:5432/postgres?sslmode=require

# Auth
JWT_SECRET=your-min-32-char-random-string-here-please-change
JWT_EXPIRY_HOURS=24

# Google Gemini
GEMINI_API_KEY=your-google-ai-studio-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# Execution
EXECUTOR_MAX_CONCURRENCY=2
EXECUTOR_TIMEOUT_SECONDS=5
DOCKER_IMAGE=golang:1.22-alpine
SANDBOX_BASE_DIR=/tmp/koder
BUILD_CACHE_DIR=/tmp/go-build-cache

# Server
PORT=8080
ENVIRONMENT=production

# CORS
ALLOWED_ORIGIN=https://koder.vercel.app
