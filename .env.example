# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=                                    # PostgreSQL (Supabase) connection string (required)

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=                                      # HS256 signing key, min 32 characters (required)
JWT_EXPIRY_HOURS=24                              # Legacy JWT expiry in hours (unused with refresh tokens)
ACCESS_TOKEN_EXPIRY_MINUTES=15                   # Access token lifetime in minutes
REFRESH_TOKEN_EXPIRY_DAYS=7                      # Refresh token rotation window in days

# ── AI Enrichment (NVIDIA NIM — DeepSeek V4 Flash) ───────────────────────
ENRICHMENT_PROVIDER=nvidia                       # Must be "nvidia" (only supported provider)
NVIDIA_API_KEY=                                  # NVIDIA NIM API key for DeepSeek V4 Flash (required)
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash       # NVIDIA model name
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1  # NVIDIA NIM API base URL

# ── Execution ─────────────────────────────────────────────────────────────
EXECUTOR_MAX_CONCURRENCY=6                       # Max concurrent code executions (semaphore)
EXECUTOR_TIMEOUT_SECONDS=30                      # Per-execution timeout in seconds
DOCKER_IMAGE=golang:1.23-alpine                  # Docker image for Go sandbox
SANDBOX_BASE_DIR=/tmp/koder                      # Temp directory for sandbox files
BUILD_CACHE_DIR=/tmp/go-build-cache              # Go build cache directory

# ── Sandbox (Empty = local Docker) ────────────────────────────────────────
SANDBOX_URL=                                     # Remote Railway sandbox endpoint for production
PYTHON_SANDBOX_URL=                              # Separate sandbox URL for Python (optional)

# ── Go Version ────────────────────────────────────────────────────────────
GO_VERSION=1.23                                  # Go version directive in generated go.mod

# ── Python Execution ──────────────────────────────────────────────────────
PYTHON_DOCKER_IMAGE=python:3.12-slim             # Docker image for Python sandbox
PYTHON_EXECUTOR_TIMEOUT_SECONDS=60               # Per-Python-execution timeout in seconds

# ── Server ────────────────────────────────────────────────────────────────
PORT=8080                                        # HTTP server port (1–65535)
ENVIRONMENT=development                          # "development" or "production"

# ── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                                # Google OAuth client ID (required for Google Sign-In)

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=                                  # Resend.com API key for transactional emails
EMAIL_FROM=Koder <noreply@koder.sbs>            # Verified sender address in Resend

# ── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_URL=                                    # Frontend URL for password reset links (required in production)

# ── CORS — MUST be set in production ──────────────────────────────────────
# ALLOWED_ORIGINS (plural) preferred; ALLOWED_ORIGIN (singular) legacy fallback
ALLOWED_ORIGINS=                                 # Comma-separated list of allowed origins
# ALLOWED_ORIGIN=                                # Legacy single-origin (use ALLOWED_ORIGINS instead)

# ── Admin ─────────────────────────────────────────────────────────────────
ADMIN_EMAIL=                                     # Admin account email (created on first startup)
ADMIN_PASSWORD=                                  # Admin account password

# ── Build Info (set via -ldflags at build time) ───────────────────────────
BUILD_COMMIT=dev
BUILD_TIME=unknown
