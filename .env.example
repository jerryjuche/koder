# Database
DATABASE_URL=

# Auth
JWT_SECRET=                                       # min 32 characters
JWT_EXPIRY_HOURS=24                               # legacy JWT expiry (unused with refresh tokens)
ACCESS_TOKEN_EXPIRY_MINUTES=15                    # short-lived access tokens for refresh token flow
REFRESH_TOKEN_EXPIRY_DAYS=7                       # refresh token rotation window

# AI Enrichment Provider (NVIDIA NIM — DeepSeek V4 Flash)
ENRICHMENT_PROVIDER=nvidia
NVIDIA_API_KEY=                                   # NVIDIA NIM API key for DeepSeek V4 Flash

# Execution
EXECUTOR_MAX_CONCURRENCY=6
EXECUTOR_TIMEOUT_SECONDS=30
DOCKER_IMAGE=golang:1.23-alpine
SANDBOX_BASE_DIR=/tmp/koder
BUILD_CACHE_DIR=/tmp/go-build-cache

# Sandbox (optional — empty = use local Docker)
SANDBOX_URL=https://koder-production.up.railway.app

# Go version for generated test modules (default "1.23")
GO_VERSION=1.23

# Python execution (optional — empty = Python not available)
PYTHON_DOCKER_IMAGE=python:3.12-slim
PYTHON_EXECUTOR_TIMEOUT_SECONDS=60
PYTHON_SANDBOX_URL=

# Server
PORT=8080
ENVIRONMENT=development                           # "development" or "production"

# Google OAuth2 (for Sign-In)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Resend (email notifications for feedback + password reset)
RESEND_API_KEY=

# Frontend URL (for password reset links in emails)
FRONTEND_URL=https://koder1.vercel.app

# CORS
ALLOWED_ORIGIN=https://koder1.vercel.app
